{
  "name": "local-llm-gateway-4-kiro",
  "version": "1.1.0",
  "description": "Anthropic-compatible local API gateway for Kiro IDE — powered by SSO credentials",
  "bin": {
    "llm-gateway": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs --banner:js=\"#!/usr/bin/env node\"",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [
    "kiro",
    "anthropic",
    "gateway",
    "proxy",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  }
}
